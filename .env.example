# Local development (matches docker-compose.yml Postgres service)
DATABASE_URL=postgresql://giss:giss_dev_password@localhost:5432/giss

# Used by Payload to sign JWTs, cookies, etc. Generate a new one for production.
# Any random 64+ character string works; node -e "console.log(crypto.randomBytes(48).toString('hex'))"
PAYLOAD_SECRET=replace-me-with-a-random-string

# Public URL of the frontend (used for absolute links, emails, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
