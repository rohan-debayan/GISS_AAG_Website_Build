{
  "name": "aag-giss-site",
  "version": "0.1.0",
  "description": "AAG GISS-SG website — Next.js 16 + Payload 3.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=4096\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "import:wp": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/import-wordpress.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.83.0",
    "@payloadcms/email-resend": "^3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "@payloadcms/ui": "3.83.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.3",
    "payload": "3.83.0",
    "pdfjs-dist": "^5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.0.2",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "picomatch": "^4"
  }
}
